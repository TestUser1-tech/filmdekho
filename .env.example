# Sanity CMS — create project at sanity.io
# Project ID (lowercase letters, numbers, dashes only — copy from sanity.io/manage, not the display name)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_secret_token

# Site URL (used for OG URLs, sitemap, share links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Analytics 4
NEXT_PUBLIC_GA_ID=

# Google AdSense (publisher ID ca-pub-...)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# TMDB — themoviedb.org API key (for /api/movies)
TMDB_API_KEY=

# Newsletter (optional)
MAILCHIMP_API_KEY=
